# Copy to .env for local development, or set these as environment variables on
# Vercel. Local dev works with NONE of these set (SQLite + console email).

# --- Core ---
DEBUG=True
SECRET_KEY=change-me-to-a-long-random-string
# Comma-separated; Vercel's own host is added automatically.
ALLOWED_HOSTS=
CSRF_TRUSTED_ORIGINS=
SITE_URL=http://localhost:8000

# --- Database (production) ---
# Point at the provider's TRANSACTION-MODE POOLER endpoint, not the direct one:
#   Supabase Supavisor:  ...pooler.supabase.com:6543/postgres
#   Neon pooled:         ...-pooler.<region>.aws.neon.tech/<db>
# Leave unset locally to use SQLite.
# DATABASE_URL=postgres://user:pass@host:6543/dbname
DB_SSL_REQUIRE=True

# --- Email (Resend chosen; console fallback in dev) ---
EMAIL_PROVIDER=auto            # auto | resend | console | smtp
RESEND_API_KEY=
# Must be a verified Resend sending domain.
DEFAULT_FROM_EMAIL=K.H.S.S.C. Tipsters <tipsters@pageforge.co.uk>
# SMTP fallback (only when EMAIL_PROVIDER=smtp)
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True

# --- Results provider (API-Football chosen; manual fallback) ---
RESULTS_PROVIDER=auto          # auto | apifootball | manual
APIFOOTBALL_API_KEY=
APIFOOTBALL_BASE_URL=https://v3.football.api-sports.io

# --- Reminders / cron ---
# Hours-before-deadline windows at which to email non-submitters.
# Default "24" suits Vercel Hobby (cron runs once/day). With Pro or an external
# hourly trigger you can use multiple windows, e.g. "24,3".
REMINDER_WINDOWS_HOURS=24
# Shared secret Vercel Cron sends as `Authorization: Bearer <CRON_SECRET>`.
CRON_SECRET=change-me-to-a-long-random-string
